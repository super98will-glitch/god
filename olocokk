-- ================= FUNÇÕES BASE =================
local function isCharacter(model)
	return model:FindFirstChildOfClass("Humanoid") ~= nil
end

local activated = false
local rtxActive = false
local rtxEffects = {}

local function optimizeUltraLowPoly()
	-- Lighting
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 1e9
	Lighting.Brightness = 2

	-- Terrain
	local terrain = Workspace:FindFirstChildOfClass("Terrain")
	if terrain then
		terrain.WaterWaveSize = 0
		terrain.WaterWaveSpeed = 0
		terrain.WaterReflectance = 0
		terrain.WaterTransparency = 1
	end

	for _, obj in pairs(Workspace:GetDescendants()) do
		if obj:IsA("Terrain") then continue end
		local model = obj:FindFirstAncestorOfClass("Model")
		if model and isCharacter(model) then
			for _, part in pairs(model:GetDescendants()) do
				if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
					local originalTrans = part.Transparency
					part.Material = Enum.Material.SmoothPlastic
					part.Reflectance = 0
					part.CastShadow = false
					part.Transparency = originalTrans
				end
			end
			continue
		end
		if obj:IsA("BasePart") and obj.Anchored and obj.CanCollide then
			obj.Material = Enum.Material.SmoothPlastic
			obj.Reflectance = 0
			obj.CastShadow = false
			obj.Transparency = 0
			continue
		end
		if obj.Name:lower():match("tree") or obj.Name:lower():match("rock") then
			obj:Destroy()
		elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
			obj.Enabled = false
		elseif obj:IsA("BasePart") then
			obj:Destroy()
		end
	end
end

