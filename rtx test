-- ================= FUNÇÕES =================
local function isCharacter(model)
	return model:FindFirstChildOfClass("Humanoid") ~= nil
end

local activated = false
local rtxActive = false
local rtxEffects = {}

local function optimizeUltraLowPoly()
	-- Lighting
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 1e9
	Lighting.Brightness = 2

	-- Terrain
	local terrain = Workspace:FindFirstChildOfClass("Terrain")
	if terrain then
		terrain.WaterWaveSize = 0
		terrain.WaterWaveSpeed = 0
		terrain.WaterReflectance = 0
		terrain.WaterTransparency = 1
	end

	-- Remove árvores, pedras e props soltos, mantém chão, paredes, NPCs e players
	for _, obj in pairs(Workspace:GetDescendants()) do
		if obj:IsA("Terrain") then continue end
		local model = obj:FindFirstAncestorOfClass("Model")
		if model and isCharacter(model) then
			-- Preserva transparência original
			for _, part in pairs(model:GetDescendants()) do
				if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
					local originalTrans = part.Transparency
					part.Material = Enum.Material.SmoothPlastic
					part.Reflectance = 0
					part.CastShadow = false
					part.Transparency = originalTrans
				end
			end
			continue
		end
		-- Mantém partes fixas do chão e paredes
		if obj:IsA("BasePart") and obj.Anchored and obj.CanCollide then
			obj.Material = Enum.Material.SmoothPlastic
			obj.Reflectance = 0
			obj.CastShadow = false
			obj.Transparency = 0
			continue
		end
		-- Remove props e árvores
		if obj.Name:lower():match("tree") or obj.Name:lower():match("rock") then
			obj:Destroy()
		elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
			obj.Enabled = false
		elseif obj:IsA("BasePart") then
			obj:Destroy()
		end
	end
end

-- ================= FUNÇÃO RTX =================
local function toggleRTX(enable)
	if enable and not rtxActive then
		-- Ativar RTX
		
		-- 1. Bloom (brilho)
		local bloom = Instance.new("BloomEffect")
		bloom.Intensity = 0.5
		bloom.Size = 24
		bloom.Threshold = 2
		bloom.Parent = Lighting
		table.insert(rtxEffects, bloom)
		
		-- 2. ColorCorrection (cores mais vibrantes)
		local colorCorrection = Instance.new("ColorCorrectionEffect")
		colorCorrection.Brightness = 0.1
		colorCorrection.Contrast = 0.2
		colorCorrection.Saturation = 0.3
		colorCorrection.TintColor = Color3.fromRGB(255, 240, 220) -- tom quente
		colorCorrection.Parent = Lighting
		table.insert(rtxEffects, colorCorrection)
		
		-- 3. SunRays (raios de sol)
		local sunRays = Instance.new("SunRaysEffect")
		sunRays.Intensity = 0.1
		sunRays.Spread = 0.5
		sunRays.Parent = Lighting
		table.insert(rtxEffects, sunRays)
		
		-- 4. DepthOfField (desfoque de fundo - suave)
		local depthOfField = Instance.new("DepthOfFieldEffect")
		depthOfField.FarIntensity = 0.5
		depthOfField.FocusDistance = 30
		depthOfField.InFocusRadius = 20
		depthOfField.NearIntensity = 0.5
		depthOfField.Parent = Lighting
		table.insert(rtxEffects, depthOfField)
		
		-- Ajustes no Lighting
		Lighting.Ambient = Color3.fromRGB(40, 40, 50)
		Lighting.Brightness = 1.5
		Lighting.ColorShift_Bottom = Color3.fromRGB(20, 20, 30)
		Lighting.ColorShift_Top = Color3.fromRGB(220, 200, 180)
		Lighting.EnvironmentDiffuseScale = 0.5
		Lighting.EnvironmentSpecularScale = 0.5
		Lighting.GlobalShadows = true
		Lighting.OutdoorAmbient = Color3.fromRGB(100, 100, 120)
		Lighting.ShadowSoftness = 0.2
		
		rtxActive = true
		
	elseif not enable and rtxActive then
		-- Desativar RTX
		for _, effect in ipairs(rtxEffects) do
			effect:Destroy()
		end
		rtxEffects = {}
		
		-- Restaurar Lighting (valores do ultra low poly)
		Lighting.Ambient = Color3.new(0, 0, 0)
		Lighting.Brightness = 2
		Lighting.ColorShift_Bottom = Color3.new(0, 0, 0)
		Lighting.ColorShift_Top = Color3.new(0, 0, 0)
		Lighting.EnvironmentDiffuseScale = 1
		Lighting.EnvironmentSpecularScale = 1
		Lighting.GlobalShadows = false
		Lighting.OutdoorAmbient = Color3.new(0, 0, 0)
		Lighting.ShadowSoftness = 0
		
		rtxActive = false
	end
end

