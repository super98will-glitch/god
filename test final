	{ Name = "Sunny Sky", TextureId = "rbxassetid://140664609" },
	{ Name = "Night Sky", TextureId = "rbxassetid://395375914" },
}

local function applySky(skyData)
	for _, oldSky in pairs(Lighting:GetChildren()) do
		if oldSky:IsA("Sky") then oldSky:Destroy() end
	end
	local sky = Instance.new("Sky")
	sky.Name = "CustomSky"
	sky.SkyboxBk = skyData.TextureId
	sky.SkyboxDn = skyData.TextureId
	sky.SkyboxFt = skyData.TextureId
	sky.SkyboxLf = skyData.TextureId
	sky.SkyboxRt = skyData.TextureId
	sky.SkyboxUp = skyData.TextureId
	sky.Parent = Lighting
end

